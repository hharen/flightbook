<% content_for :title, t('.title') %>

<p style="color: green"><%= notice %></p>

<div class="profile-header">
  <h1><%= @user.name %></h1>
  <%= link_to t('.edit_link'), edit_profile_path, class: "btn btn-primary" %>
</div>

<div class="profile-stats">
  <div class="stat-card">
    <div class="stat-value"><%= @sessions_count %></div>
    <div class="stat-label"><%= t('.flying_sessions') %></div>
  </div>

  <div class="stat-card">
    <div class="stat-value"><%= @total_flights %></div>
    <div class="stat-label"><%= t('.total_flights') %></div>
  </div>

  <div class="stat-card">
    <% if @total_flight_time > 0 %>
      <div class="stat-value"><%= (@total_flight_time / 60.0).round(1) %></div>
      <div class="stat-label"><%= t('.hours_airborne') %></div>
      <div class="stat-sub"><%= @total_flight_time %> min</div>
    <% else %>
      <div class="stat-value">&mdash;</div>
      <div class="stat-label"><%= t('.hours_airborne') %></div>
    <% end %>
  </div>
</div>
