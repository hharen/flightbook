<% content_for :title, t('.title') %>

<div class="profile-header">
  <h1><%= t('.heading') %></h1>
  <%= link_to t('.back_link'), profile_path, class: "btn btn-secondary" %>
</div>

<div class="form-container">
  <%= form_with model: @user, url: profile_path, method: :patch do |form| %>
    <% if @user.errors.any? %>
      <div class="form-errors">
        <ul>
          <% @user.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="form-group">
      <%= form.label :name %>
      <%= form.text_field :name %>
    </div>

    <div class="form-group">
      <%= form.label :email %>
      <%= form.email_field :email %>
    </div>

    <div class="form-group">
      <%= form.label :password, t('.new_password_label') %>
      <%= form.password_field :password %>
    </div>

    <div class="form-group">
      <%= form.label :password_confirmation %>
      <%= form.password_field :password_confirmation %>
    </div>

    <div class="action-buttons">
      <%= form.submit t('.save_button'), class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
